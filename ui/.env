# ID for the Dataneed to create correct permissions via EDDIE button
VITE_EDDIE_HISTORIC_DATANEED_ID=a32c5da1-2ca6-426b-8438-21d5b33e3b12
VITE_EDDIE_REALTIME_DATANEED_ID=d3aa2f01-f1be-436a-bcac-d2e0dae95848
# URL of example app backend
VITE_BACKEND_BASE_URL=http://localhost:8080