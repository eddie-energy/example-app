# Required for Keycloak authentication
VITE_KEYCLOAK_URL=https://eddie-demo.projekte.fh-hagenberg.at/iam/
VITE_KEYCLOAK_REALM=EDDIE
VITE_KEYCLOAK_CLIENT=example-app-client
# URL of the EDDIE Instance
